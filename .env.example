ONOFFICE_URL=https://api.onoffice.de/api/stable/api.php
ONOFFICE_TOKEN=your_onoffice_token_here
ONOFFICE_SECRET=your_onoffice_secret_here

# API server
EXPORT_API_PORT=your_desired_port_here
EXPORT_API_TIME_SKEW_SEC=300

# Authorized users for GET /apartments.
# JSON array with one or more objects: { "id": "...", "token": "...", "secret": "..." }
EXPORT_API_USERS=[{"id":"user_name","token":"demo_token","secret":"demo_secret_change_me"}]
